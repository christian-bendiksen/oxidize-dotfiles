{
  "name": "Aeryn",
  "type": "dark",
  "colors": {
    "foreground": "#CFCAB2",
    "descriptionForeground": "#8F947F",
    "errorForeground": "#C07A4F",
    "focusBorder": "#A4B46599",
    "selection.background": "#A4B46555",
    "textLink.foreground": "#A4B465",
    "textLink.activeForeground": "#F0BB78",

    "activityBar.background": "#151A16",
    "activityBar.foreground": "#E6DDC7",
    "activityBar.inactiveForeground": "#7E7A66",
    "activityBarBadge.background": "#A4B465",
    "activityBarBadge.foreground": "#151A16",

    "sideBar.background": "#151A16",
    "sideBar.foreground": "#CFCAB2",
    "sideBar.border": "#273028",
    "sideBarTitle.foreground": "#E6DDC7",
    "sideBarSectionHeader.background": "#1E2520",
    "sideBarSectionHeader.foreground": "#CFCAB2",

    "editor.background": "#151A16",
    "editor.foreground": "#CFCAB2",
    "editorLineNumber.foreground": "#626F47",
    "editorLineNumber.activeForeground": "#A4B465",
    "editorCursor.foreground": "#F0BB78",
    "editor.selectionBackground": "#A4B46544",
    "editor.inactiveSelectionBackground": "#626F4733",
    "editor.lineHighlightBackground": "#1E2520",
    "editorIndentGuide.background1": "#273028",
    "editorIndentGuide.activeBackground1": "#626F47",
    "editorWhitespace.foreground": "#273028",

    "editorWidget.background": "#1E2520",
    "editorWidget.foreground": "#CFCAB2",
    "editorWidget.border": "#273028",
    "editorSuggestWidget.background": "#1E2520",
    "editorSuggestWidget.foreground": "#CFCAB2",
    "editorSuggestWidget.selectedBackground": "#273028",
    "editorSuggestWidget.highlightForeground": "#F0BB78",

    "panel.background": "#151A16",
    "panel.border": "#273028",
    "terminal.background": "#151A16",
    "terminal.foreground": "#CFCAB2",
    "terminalCursor.foreground": "#F0BB78",
    "terminal.ansiBlack": "#151A16",
    "terminal.ansiRed": "#C07A4F",
    "terminal.ansiGreen": "#A4B465",
    "terminal.ansiYellow": "#F0BB78",
    "terminal.ansiBlue": "#626F47",
    "terminal.ansiMagenta": "#7E7A66",
    "terminal.ansiCyan": "#6F8F7A",
    "terminal.ansiWhite": "#CFCAB2",
    "terminal.ansiBrightBlack": "#1E2520",
    "terminal.ansiBrightRed": "#F0BB78",
    "terminal.ansiBrightGreen": "#A4B465",
    "terminal.ansiBrightYellow": "#E6DDC7",
    "terminal.ansiBrightBlue": "#7F9168",
    "terminal.ansiBrightMagenta": "#8F947F",
    "terminal.ansiBrightCyan": "#7FA696",
    "terminal.ansiBrightWhite": "#F5ECD5",

    "statusBar.background": "#1E2520",
    "statusBar.foreground": "#CFCAB2",
    "statusBar.border": "#273028",
    "statusBarItem.remoteBackground": "#A4B465",
    "statusBarItem.remoteForeground": "#151A16",
    "titleBar.activeBackground": "#151A16",
    "titleBar.activeForeground": "#E6DDC7",
    "titleBar.inactiveBackground": "#151A16",
    "titleBar.inactiveForeground": "#7E7A66",

    "button.background": "#626F47",
    "button.foreground": "#F5ECD5",
    "button.hoverBackground": "#A4B465",
    "input.background": "#1E2520",
    "input.foreground": "#CFCAB2",
    "input.border": "#273028",
    "dropdown.background": "#1E2520",
    "dropdown.foreground": "#CFCAB2",
    "dropdown.border": "#273028",

    "list.activeSelectionBackground": "#A4B46533",
    "list.activeSelectionForeground": "#F5ECD5",
    "list.hoverBackground": "#1E2520",
    "list.highlightForeground": "#F0BB78",
    "list.inactiveSelectionBackground": "#626F4722"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#7E7A66", "fontStyle": "italic" } },
    { "scope": ["string", "markup.inline.raw.string"], "settings": { "foreground": "#A4B465" } },
    { "scope": ["constant.numeric", "constant.language", "constant.character"], "settings": { "foreground": "#F0BB78" } },
    { "scope": ["keyword", "storage", "storage.type"], "settings": { "foreground": "#8F947F" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#7F9168" } },
    { "scope": ["entity.name.type", "support.type", "support.class"], "settings": { "foreground": "#E6DDC7" } },
    { "scope": ["variable", "entity.name.variable", "support.variable"], "settings": { "foreground": "#CFCAB2" } },
    { "scope": ["entity.other.attribute-name", "variable.parameter"], "settings": { "foreground": "#F5ECD5" } },
    { "scope": ["keyword.operator", "punctuation.separator", "punctuation.terminator"], "settings": { "foreground": "#7FA696" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#F5ECD5", "fontStyle": "bold" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#F0BB78" } },
    { "scope": ["markup.deleted", "invalid"], "settings": { "foreground": "#C07A4F" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#A4B465" } }
  ]
}
