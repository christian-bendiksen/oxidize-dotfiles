#!/usr/bin/env bash
# oxidize-sysctl — walker-driven system controls menu.

set -euo pipefail

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
TERMINALS_LIST="$XDG_CONFIG_HOME/xdg-terminals.list"
DESKTOP_DIRS=(
    "$HOME/.local/share/applications"
    /usr/local/share/applications
    /usr/share/applications
)

notify() {
    command -v notify-send >/dev/null 2>&1 && notify-send "$@" || printf '%s\n' "$*" >&2
}

pick() {
    local out
    out="$(walker --dmenu --placeholder "$1")" || return 1
    [ -n "$out" ] || return 1
    printf '%s\n' "$out"
}

desktop_field() {
    awk -v key="$2" '
        /^\[/ { in_default = ($0 == "[Desktop Entry]") }
        in_default && $0 ~ "^"key"=" {
            sub("^"key"=", "")
            print
            exit
        }
    ' "$1"
}

list_desktops() {
    local pattern="$1"
    local seen=""
    local dir file base name
    for dir in "${DESKTOP_DIRS[@]}"; do
        [[ -d "$dir" ]] || continue
        for file in "$dir"/*.desktop; do
            [[ -r "$file" ]] || continue
            base="$(basename "$file")"
            case ":$seen:" in *":$base:"*) continue ;; esac
            grep -qE "$pattern" "$file" || continue
            [[ "$(desktop_field "$file" Hidden)" == "true" ]] && continue
            [[ "$(desktop_field "$file" NoDisplay)" == "true" ]] && continue
            name="$(desktop_field "$file" Name)"
            [[ -z "$name" ]] && name="$base"
            printf '%s|%s\n' "$name" "$base"
            seen="$seen:$base"
        done
    done | sort -f
}

choose_desktop() {
    local label="$1" pattern="$2"
    local choices name file
    choices="$(list_desktops "$pattern")"
    [[ -z "$choices" ]] && { notify "oxidize-sysctl" "No candidates found for $label"; return 1; }
    name="$(printf '%s\n' "$choices" | cut -d'|' -f1 | pick "$label")" || return 1
    [[ -z "$name" ]] && return 1
    file="$(printf '%s\n' "$choices" | awk -F'|' -v n="$name" '$1 == n { print $2; exit }')"
    [[ -z "$file" ]] && return 1
    printf '%s\n' "$file"
}

set_terminal() {
    local file
    file="$(choose_desktop "Default terminal" '^Categories=.*TerminalEmulator')" || return 0
    mkdir -p "$(dirname "$TERMINALS_LIST")"
    printf '%s\n' "$file" > "$TERMINALS_LIST"
    notify "Default terminal" "$file"
}

set_browser() {
    local file
    file="$(choose_desktop "Default browser" '^MimeType=.*x-scheme-handler/https')" || return 0
    xdg-mime default "$file" \
        x-scheme-handler/http \
        x-scheme-handler/https \
        text/html \
        application/xhtml+xml
    notify "Default browser" "$file"
}

set_file_manager() {
    local file
    file="$(choose_desktop "Default file manager" '^MimeType=.*inode/directory')" || return 0
    xdg-mime default "$file" inode/directory
    notify "Default file manager" "$file"
}

set_editor() {
    local file
    file="$(choose_desktop "Default editor" '^Categories=.*TextEditor')" || return 0
    xdg-mime default "$file" text/plain
    notify "Default editor" "$file"
}

compositor_quit() {
    case "${XDG_CURRENT_DESKTOP:-}" in
        *niri*) niri msg action quit ;;
        *)
            if pgrep -x niri >/dev/null; then niri msg action quit
            elif pgrep -x mango >/dev/null; then pkill -TERM -x mango
            elif pgrep -x Hyprland >/dev/null; then hyprctl dispatch exit
            else notify "oxidize-sysctl" "Unknown compositor — cannot log out"
            fi
            ;;
    esac
}

power_menu() {
    while true; do
        local choice
        choice="$(printf '%s\n' Lock Suspend Reboot Shutdown Logout | pick "Power")" || return 1
        case "$choice" in
            Lock)     swaylock ;;
            Suspend)  systemctl suspend ;;
            Reboot)   systemctl reboot ;;
            Shutdown) systemctl poweroff ;;
            Logout)   compositor_quit ;;
        esac
    done
}

toggle_dnd() {
    if ! command -v makoctl >/dev/null 2>&1; then
        notify "oxidize-sysctl" "makoctl not found"
        return 0
    fi
    if makoctl mode | grep -qx dnd; then
        makoctl mode -r dnd
        notify "Do Not Disturb" "Off"
    else
        makoctl mode -a dnd
        notify "Do Not Disturb" "On"
    fi
}

toggle_idle_inhibitor() {
    local pid state
    pid="$(pgrep -x swayidle | head -n1 || true)"
    if [[ -z "$pid" ]]; then
        notify "Idle inhibitor" "swayidle is not running"
        return 0
    fi
    state="$(ps -o state= -p "$pid" | tr -d ' ')"
    if [[ "$state" == T* ]]; then
        kill -CONT "$pid"
        notify "Idle inhibitor" "Off (swayidle resumed)"
    else
        kill -STOP "$pid"
        notify "Idle inhibitor" "On (swayidle paused)"
    fi
}

defaults_menu() {
    while true; do
        local choice
        choice="$(printf '%s\n' \
            "Terminal" \
            "Browser" \
            "File manager" \
            "Editor" \
            | pick "Default apps")" || return 1
        case "$choice" in
            Terminal)       set_terminal ;;
            Browser)        set_browser ;;
            "File manager") set_file_manager ;;
            Editor)         set_editor ;;
        esac
    done
}

toggles_menu() {
    while true; do
        local choice
        choice="$(printf '%s\n' \
            "Do Not Disturb" \
            "Idle inhibitor" \
            | pick "Toggles")" || return 1
        case "$choice" in
            "Do Not Disturb")  toggle_dnd ;;
            "Idle inhibitor")  toggle_idle_inhibitor ;;
        esac
    done
}

main() {
    while true; do
        local choice
        choice="$(printf '%s\n' \
            "Defaults..." \
            "Power..." \
            "Toggles..." \
            | pick "System controls")" || exit 0
        case "$choice" in
            "Defaults...") defaults_menu && break ;;
            "Power...")    power_menu && break ;;
            "Toggles...")  toggles_menu && break ;;
        esac
    done
}

main "$@"
